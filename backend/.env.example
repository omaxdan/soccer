# SportsAPI Pro
SPORTSAPI_KEY=your_api_key_here
# Optional — set this to enable dual-key rotation (doubles daily quota
# 100 -> 200 calls/day). Requests round-robin between both keys, with
# automatic failover to the other key on a 429 rate-limit response.
# Leave unset to run on a single key (100/day) — fully backward compatible.
SPORTSAPI_KEY_2=
SPORTSAPI_BASE_URL=https://v2.football.sportsapipro.com/api

# Supabase
SUPABASE_URL=your_supabase_url_here
SUPABASE_SERVICE_KEY=your_service_key_here

# Node environment
NODE_ENV=development

# Logging
LOG_LEVEL=debug

# Cron enabled
CRON_ENABLED=false

# SofaScore API (squad intelligence — Source 2)
# Public API, no key required. Override only if using a proxy.
SOFASCORE_BASE_URL=https://api.sofascore.com/api/v1

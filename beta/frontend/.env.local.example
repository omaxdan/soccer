# Supabase (shared warehouse — same project as the pipeline)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Deployment mount point: /beta (default), /rip, or empty for domain root
NEXT_PUBLIC_BASE_PATH=/beta

# White-label identity (defaults are Pitch Terminal — see src/config/brand.ts)
NEXT_PUBLIC_BRAND_NAME=Pitch Terminal
NEXT_PUBLIC_BRAND_SHORT=PT
NEXT_PUBLIC_BRAND_TAGLINE=Football Availability Intelligence
NEXT_PUBLIC_BRAND_DOMAIN=pitchterminal.com

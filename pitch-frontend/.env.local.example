# PitchTerminal reads directly from the Supabase (PostgREST) warehouse
# populated by the NinetyData RIP backend. Set these to go live.
# Without them, PitchTerminal renders with built-in demo intelligence.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
